generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id
  name             String
  email            String            @unique
  emailVerified    Boolean           @default(false)
  image            String?
  twoFactorEnabled Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         Session[]
  accounts         Account[]
  workspaces       Workspace[]
  twoFactor        TwoFactor[]
  workspaceMembers WorkspaceMember[]
  platformRoleAssignments PlatformRoleAssignment[] @relation("PlatformRoleAssignmentUser")
  grantedPlatformRoleAssignments PlatformRoleAssignment[] @relation("PlatformRoleAssignmentGranter")
  revokedPlatformRoleAssignments PlatformRoleAssignment[] @relation("PlatformRoleAssignmentRevoker")
  securityEvents SecurityEvent[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Workspace {
  id          String                @id
  name        String
  ownerId     String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  owner       User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  lists       List[]
  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]

  @@unique([ownerId])
  @@map("workspace")
}

model WorkspaceMember {
  id          String    @id
  workspaceId String
  userId      String
  role        String    @default("member")
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_member")
}

model WorkspaceInvitation {
  id          String    @id
  workspaceId String
  email       String
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("workspace_invitation")
}

model List {
  id          String    @id
  workspaceId String
  name        String
  isInbox     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("list")
}

// Better Auth's email-verification tokens are stateless signed JWTs and are
// never persisted, so the per-email resend cooldown needs its own store.
model VerificationEmailThrottle {
  identifier String   @id
  lastSentAt DateTime @default(now())

  @@map("verification_email_throttle")
}

model TwoFactor {
  id                      String    @id
  secret                  String
  backupCodes             String
  userId                  String
  verified                Boolean   @default(true)
  failedVerificationCount Int       @default(0)
  lockedUntil             DateTime?
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("two_factor")
}

model PlatformRoleAssignment {
  id              String    @id
  userId          String
  grantedByUserId String
  grantedAt       DateTime  @default(now())
  revokedAt       DateTime?
  revokedByUserId String?
  user            User      @relation("PlatformRoleAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUser   User      @relation("PlatformRoleAssignmentGranter", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  revokedByUser   User?     @relation("PlatformRoleAssignmentRevoker", fields: [revokedByUserId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt])
  @@map("platform_role_assignment")
}

model SecurityEvent {
  id        String   @id
  type      String
  userId    String?
  email     String?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("security_event")
}

model SecurityNoticeOutbox {
  id             String   @id
  recipient      String
  type           String
  action         String?
  newEmail       String?
  status         String   @default("pending")
  attemptCount   Int      @default(0)
  nextAttemptAt  DateTime @default(now())
  lastAttemptAt  DateTime?
  deliveredAt    DateTime?
  finalFailureAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([status, finalFailureAt])
  @@map("security_notice_outbox")
}

model SecurityAlertDispatch {
  subject   String   @id
  alertedAt DateTime @default(now())

  @@map("security_alert_dispatch")
}
