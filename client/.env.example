REDIS_URL="redis://localhost:6379"
# Configure only a header your reverse proxy strips and replaces with the
# connecting client's IP address. Leave unset when no trusted proxy exists.
# AUTH_TRUSTED_PROXY_IP_HEADER="x-forwarded-for"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/listitup?schema=public"
BETTER_AUTH_SECRET="replace-with-a-random-secret-of-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"
DISCORD_SECURITY_WEBHOOK_URL=""
SECURITY_CLEANUP_SCHEDULER_SECRET="replace-with-a-scheduler-secret"

# SMTP mailer: exactly one provider is active per environment. All providers
# speak SMTP, so switching provider only means changing these values.
# MAIL_PROVIDER is a label used for logging/diagnostics, not branching logic.
# - google: low-volume dev/test (smtp.gmail.com, port 587, an app password)
# - mailgun: production (smtp.mailgun.org, port 587)
# - brevo: production (smtp-relay.brevo.com, port 587)
MAIL_PROVIDER="google"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="replace-with-smtp-username"
SMTP_PASSWORD="replace-with-smtp-password"
MAIL_FROM_NAME="ListItUp"
MAIL_FROM_EMAIL="no-reply@listitup.test"
