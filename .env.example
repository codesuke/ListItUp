# Config for `docker compose up` (see docker-compose.yml at repo root).
# Copy this file to `.env` in the same directory before starting the stack:
#   cp .env.example .env
#
# DATABASE_URL is not set here — docker-compose.yml builds it from
# POSTGRES_PASSWORD and points it at the bundled `db` service.

POSTGRES_PASSWORD="replace-with-a-strong-password"

BETTER_AUTH_SECRET="replace-with-a-random-secret-of-at-least-32-characters"
# The externally reachable URL for this instance, e.g. https://listitup.example.com
BETTER_AUTH_URL="http://localhost:3000"

# SMTP mailer: exactly one provider is active per environment. All providers
# speak SMTP, so switching provider only means changing these values.
MAIL_PROVIDER="google"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="replace-with-smtp-username"
SMTP_PASSWORD="replace-with-smtp-password"
MAIL_FROM_NAME="ListItUp"
MAIL_FROM_EMAIL="no-reply@listitup.test"
